{
    "require": {
        "php": "^8.2",
        "slim/slim": "^4.14",
        "slim/psr7": "^1.7",
        "php-di/php-di": "^7.0",
        "illuminate/database": "^11.0",
        "ramsey/uuid": "^4.7",
        "firebase/php-jwt": "^6.10",
        "guzzlehttp/guzzle": "^7.9",
        "monolog/monolog": "^3.7",
        "vlucas/phpdotenv": "^5.6",
        "defuse/php-encryption": "^2.4",
        "endroid/qr-code": "^5.0",
        "dompdf/dompdf": "^2.0",
        "stripe/stripe-php": "^15.0",
        "symfony/clock": "^7.1",
        "symfony/translation": "^7.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "start": "php -S 0.0.0.0:9000 -t public",
        "test": "phpunit"
    }
}
