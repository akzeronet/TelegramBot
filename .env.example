# =============================================================================
# AI Wrapper Premium — Variables de Entorno
# Copia este archivo como .env y completa todos los valores.
# NUNCA subas el .env real a un repositorio.
# =============================================================================

# --- Base de datos ---
POSTGRES_DB=aiwrapper
POSTGRES_USER=aiwrapper_user
POSTGRES_PASSWORD=CAMBIA_ESTO_POR_UNA_CLAVE_SEGURA

# --- Seguridad Core ---
# Clave AES-256 para cifrar bot_tokens en DB. NUNCA cambiarla una vez en producción.
# Genera con: openssl rand -hex 32
MASTER_KEY=GENERA_CON_OPENSSL_RAND_HEX_32

# Secreto JWT para API Keys de la Web App
# Genera con: openssl rand -hex 32
JWT_SECRET=GENERA_CON_OPENSSL_RAND_HEX_32

# --- Telegram ---
# Bot maestro (el bot principal de ventas y usuarios Standard)
TELEGRAM_BOT_TOKEN=123456789:ABCDEFabcdef...
# Secreto para validar que los webhooks vienen de Telegram
TELEGRAM_WEBHOOK_SECRET=GENERA_CON_OPENSSL_RAND_HEX_16

# --- Pagos ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Métodos activos (separados por coma): stripe,paypal,mercadopago,uepapay,stars
PAYMENT_METHODS_ENABLED=stripe,paypal,stars,uepapay

# --- Módulo D: OmniRoute (Proxy IA Local) ---
# Se ejecuta en su propio contenedor (puerto interno 20128).
# Esta key es solo para la autenticación interna (n8n -> OmniRoute).
# Las keys reales de los proveedores (OpenAI, etc.) se configuran en omniroute/config.yaml
OMNIROUTE_API_KEY=key_interna_segura_123

# --- n8n (Orquestador / Módulo B) ---
N8N_USER=admin
N8N_PASSWORD=CAMBIA_ESTO
N8N_HOST=n8n.tudominio.com
N8N_ENCRYPTION_KEY=GENERA_CON_OPENSSL_RAND_HEX_32
# Secreto compartido entre PHP y n8n para los webhooks internos
N8N_WEBHOOK_SECRET=GENERA_CON_OPENSSL_RAND_HEX_32
# URL interna del webhook principal de n8n para enviar mensajes
N8N_WEBHOOK_URL=http://n8n:5678/webhook/chat

# --- Configuración General ---
APP_DOMAIN=https://tudominio.com
TIMEZONE=America/Bogota
APP_ENV=production
